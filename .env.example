# Secret serveur uniquement. Ne jamais utiliser de variable NEXT_PUBLIC_* pour cette clé.
OPENAI_API_KEY=

# Missions courantes à coût maîtrisé.
OPENAI_MODEL=gpt-5.6-luna

# Photos, recherches réglementaires et analyses complexes.
OPENAI_MODEL_COMPLEX=gpt-5.6-terra

# Le mode production est toujours verrouillé sur "enforced".
# "preview" est réservé au développement et aux Pull Requests.
COMMERCE_MODE=preview

# Générer une seule fois avec : openssl rand -base64 48
# Conserver cette valeur : sa rotation invalide les sessions et empreintes existantes.
AUTH_PEPPER=

# Migration locale / secours D1 REST uniquement. Utiliser un jeton limité à cette base.
# En production Workers, l'application utilise le binding natif IMMOBOOST_DB et ce jeton n'est pas déployé.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_API_TOKEN=

# Etsy Open API v3 et webhook order.paid/order.canceled.
ETSY_SHOP_ID=
ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_REFRESH_TOKEN=
ETSY_WEBHOOK_SECRET=
ETSY_PRODUCT_CATALOG={"LISTING_ID":{"sku":"launch-be","boosts":300,"grantsAccess":true,"durationDays":null}}
# Nouvelle vente Etsy uniquement : jamais de redirection vers un paiement externe pour ce canal.
ETSY_RECHARGE_URL=https://www.etsy.com/listing/RECHARGE_LISTING_ID
# Activer uniquement après validation écrite de la politique Etsy applicable au parcours.
ETSY_DIRECT_UPGRADE_ENABLED=false

# Canal direct optionnel : achats, recharges et abonnements Lemon Squeezy.
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMON_PRODUCT_CATALOG={"VARIANT_ID":{"sku":"boost-300","boosts":300,"grantsAccess":true,"durationDays":null}}

# Paiements propres à ImmoBoost : Lemon Squeezy ou liens de paiement Stripe validés.
DIRECT_RECHARGE_URL=https://YOUR_STORE.lemonsqueezy.com/buy/RECHARGE_CHECKOUT_ID
DIRECT_SUBSCRIPTION_URL=https://YOUR_STORE.lemonsqueezy.com/buy/SUBSCRIPTION_CHECKOUT_ID

# Accès à la page privée /pilot. Générer avec : openssl rand -base64 48
PILOT_ADMIN_SECRET=
